# Local .terraform directories
**/.terraform/*
!.terraform/modules
!.terraform/providers
.terraform

# Terraform state files
*.tfstate
*.tfstate.*
terraform.tfstate.d/**

# Crash logs
crash.log

# Ignore override files
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output
*.tfplan

# CLI configuration files
.terraformrc
terraform.rc

# Intellij
.idea/**

